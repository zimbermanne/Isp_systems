# ── Copy this to Railway → Variables ──────────────────────────────────────────
# DATABASE_URL is set automatically by Railway when you add a PostgreSQL plugin.

# Azampay (get from https://azampay.co.tz/developer)
AZAMPAY_BASE_URL=https://sandbox.azampay.co.tz
AZAMPAY_APP_NAME=MoshiHotspot
AZAMPAY_CLIENT_ID=your_client_id_here
AZAMPAY_SECRET=your_secret_here
AZAMPAY_WEBHOOK_SECRET=make_up_a_random_string

# TP-Link Omada Cloud (get from https://developer.tp-link.com/omada)
OMADA_BASE_URL=https://use1-omada-cloud.tplinkcloud.com
OMADA_CLIENT_ID=your_omada_client_id
OMADA_CLIENT_SECRET=your_omada_secret
OMADA_OMADAC_ID=your_controller_id
OMADA_SITE_NAME=moshi-busstation

# Admin dashboard
ADMIN_API_KEY=choose_a_strong_secret_key
